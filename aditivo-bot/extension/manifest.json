{
  "name": "AditivoBot",
  "version": "1.0",
  "manifest_version": 3,
  "host_permissions": [
    "https://aditivosqualitor.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://aditivosqualitor.com/Private-site/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "nativeMessaging"
  ]
}